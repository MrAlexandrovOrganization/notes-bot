# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
ROOT_ID=your_telegram_id_here

# Database Configuration (REQUIRED)
# These credentials are used by PostgreSQL and notifications service
DB_NAME=notifications
DB_USER=notif
DB_PASSWORD=change_this_password_in_production

# Notes Directory Configuration (REQUIRED)
# Path to your notes directory
#
# For local run: specify full path on your machine
# Example: /home/maxim/Yandex.Disk/notes
#
# For Docker: same path will be automatically mapped to /notes inside container
# (docker-compose.yml handles the path translation)
NOTES_DIR=/path/to/your/notes

# Template Subdirectory (OPTIONAL)
# Relative path from NOTES_DIR to templates folder
# Default: Templates
# TEMPLATE_SUBDIR=Templates

# Настройки pgAdmin (веб-интерфейс для базы данных)
# Доступен по адресу: http://localhost:5050
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme_pgadmin_password

# Grafana
GRAFANA_PASSWORD=changeme_grafana_password

# Search Service Configuration
# Separate Postgres (pgvector) instance dedicated to the vault index.
SEARCH_DB_NAME=search
SEARCH_DB_USER=search
SEARCH_DB_PASSWORD=changeme_search_password
# How often the indexer rewalks the vault.
SEARCH_INDEX_INTERVAL=5m
# Embedding model and dimension (phase 2). Toggle to enable semantic search.
SEARCH_ENABLE_EMBEDDINGS=true
# Тег модели в Ollama должен совпадать с тем, что показывает `ollama list`.
# По умолчанию `ollama pull bge-m3` сохраняет её как `bge-m3:567m`, а не `bge-m3:latest`.
SEARCH_EMBED_MODEL=bge-m3:567m
SEARCH_EMBED_DIM=1024
# Сколько заметок без чанков обрабатывать за один тик индексатора.
# 0 = снять ограничение (выкачать весь backlog за один проход — подходит для первичного прогрева).
# Поставьте число, если боитесь нагрузить Ollama при большом vault.
SEARCH_BACKFILL_BATCH_PER_PASS=0
